# ─── Supabase (required for blog) ────────────────────────────────────────────
# Create a free project at https://supabase.com, then copy these from:
# Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ─── Blog admin ───────────────────────────────────────────────────────────────
# The admin account is created once inside your Supabase dashboard:
# Authentication → Users → "Invite user" (or Add user)
# Then log in at /blog/admin with that email + password.
